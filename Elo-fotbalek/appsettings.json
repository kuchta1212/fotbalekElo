{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Cors": {
    "AllowedOrigins": [
      "http://elo-fotbalek.azurewebsites.net",
      "https://elo-fotbalek.azurewebsites.net",
      "https://usti-elo-fotbalek.azurewebsites.net"
    ]
  },

  "BlobStorage": {
    "ConnectionString": "{ConnectionString}",
    "ContainerName": "{ContainerName}",
    "PlayersBlobName": "players",
    "MatchesBlobName": "matches",
    "UsersBlobName": "users",
    "DoodleBlobName": "doodle",
    "UseOffline": false
  },

  "AppConfiguration": {
    "AppName": "{AppName}",
    "IsSeasoningSupported": "{IsSeasoningSupported}",
    "NonRegularsTitle": "{NonRegularsTitle}",
    "PlayerLimit": "{PlayerLimit}",
    "OverLimitMessage": "{OverLimitMessage}",
    "IsSmallMatchesEnabled": "{IsSmallMatchesEnabled}",
    "IsJirkaLunakEnabled": "{IsJirkaLunakEnabled}",
    "BackgroundImages": "{BackgroundImages}",
    "IsDoodleEnabled": "{IsDoodleEnabled}",
    "AmountOfMonthsToBeCounted": 6
  }
}
